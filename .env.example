APP_ENV=dev
APP_DEBUG=0
DEFAULT_URI=https://your-ngrok-or-api-host.example
APP_URL=https://your-ngrok-or-api-host.example
DATABASE_URL="mysql://<user>:<password>@127.0.0.1:3306/staygrid"
APP_SECRET=replace-with-app-secret

MESSENGER_TRANSPORT_DSN=sync://
MAILER_DSN=smtp://<user>:<password>@smtp-relay.brevo.com:587

MYSQL_ROOT_PASSWORD=replace-with-root-password
MYSQL_DATABASE=staygrid
MYSQL_USER=staygrid_user
MYSQL_PASSWORD=replace-with-db-password

APP_PORT=8080
display_errors=On
log_errors=On
error_reporting=E_ALL

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> Google OAuth ###
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
###< Google OAuth ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=replace-with-jwt-passphrase
###< lexik/jwt-authentication-bundle ###

MAILER_SENDER=sender@example.com
MAILER_FROM="StayGrid <sender@example.com>"
